# Example .env file — copy to .env and fill in real values

# MongoDB configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/freshpup?retryWrites=true&w=majority

# JWT configuration
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRATION=24h

# Admin seed script (used by: node scripts/seed-admin.js)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme123
